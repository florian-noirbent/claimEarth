[node name="HelpBody" type="Label" parent="UiLayer/Center/Content/HelpPanel/HelpMargin/HelpContent" unique_id=578916850]
unique_name_in_owner = true
custom_minimum_size = Vector2(380, 0)
layout_mode = 2
theme_override_colors/font_color = Color(0.92, 0.89, 0.85, 1)
theme_override_font_sizes/font_size = 17
text = "Theme: race down toward Earth's center and plant your flag to claim the deepest point.

Rules: deeper flags score higher. Your score saves only after the flag lands on solid ground. If you die, or lava destroys the flag, the run is lost.

Controls:
A/D - move or swing
Space - jump
W/S - shorten or lengthen rope
Left mouse - throw selected item
Right mouse hold - grapple
1/2/3 - select bombs or flag
Esc - pause or close menus"
autowrap_mode = 2

